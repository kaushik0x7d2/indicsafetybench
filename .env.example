# Copy to .env and fill in actual keys. NEVER commit .env.

# Sarvam AI (https://www.sarvam.ai/)
SARVAM_API_KEY=

# Anthropic: NOT USED in this project — routed via Claude Code subagents
# ANTHROPIC_API_KEY=

# OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=

# Google Gemini (https://aistudio.google.com/apikey)
GOOGLE_API_KEY=

# Cohere (https://dashboard.cohere.com/api-keys) — for Aya models if used
COHERE_API_KEY=

# Krutrim (https://cloud.olakrutrim.com/)
KRUTRIM_API_KEY=

# Together.ai (https://api.together.xyz/) — for open models
TOGETHER_API_KEY=

# Mistral (https://console.mistral.ai/api-keys/)
MISTRAL_API_KEY=

# Moonshot AI / Kimi (https://platform.moonshot.ai/console/api-keys)
# Used for cost-efficient seed generation and rewrites
MOONSHOT_API_KEY=

# Hugging Face (https://huggingface.co/settings/tokens)
HF_TOKEN=

# OpenRouter — unified gateway for GPT-4o, Gemini, Llama, Mistral, etc.
# https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_BUDGET_USD=25.00

# Prime Intellect deployment (OpenAI-compatible serving of HF/custom models)
# Dashboard: https://app.primeintellect.ai → Deployments
# PI_ENDPOINT_URL accepts both managed deployment URLs and self-hosted vLLM:
#   https://<deployment-id>.primeintellect.ai/v1
#   http://<pod-ip>:8000/v1
PI_ENDPOINT_URL=
PI_API_KEY=

# Google Cloud Vertex AI (hosts Gemini + Anthropic Claude under one GCP project)
# Auth: either `gcloud auth application-default login` once, OR set
# GOOGLE_APPLICATION_CREDENTIALS to a service-account JSON file path.
# us-east5 hosts both Gemini and Claude; us-central1 hosts Gemini only.
GCP_PROJECT=
GCP_REGION=us-east5
# GOOGLE_APPLICATION_CREDENTIALS=  # optional; only if not using gcloud ADC
